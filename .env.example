# ============================================================
# 🔑 API Keys
# ============================================================

# Google AI Studio (Gemini)
GOOGLE_AI_STUDIO_API_KEY=your_gemini_api_key_here

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# edge-tts fallback (free — no API key needed)
# When ElevenLabs quota is exhausted, TTS auto-falls back to edge-tts.
# Leave EDGE_TTS_VOICE empty to auto-select by CONTENT_LANGUAGE.
# Arabic voices: ar-SA-HamedNeural, ar-EG-SalmaNeural, ar-AE-HamdanNeural
# English voices: en-US-EmmaMultilingualNeural, en-US-GuyNeural
# Run `edge-tts --list-voices` for the full list.
EDGE_TTS_VOICE=
TTS_FALLBACK_EDGE=true

# Pexels
PEXELS_API_KEY=your_pexels_api_key_here

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# Telegram Bot (optional — for manual approval)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# 📹 Content Settings
# ============================================================

CONTENT_LANGUAGE=ar
VIDEO_TOPIC=معلومات ونصائح يومية
VIDEO_DURATION_SECONDS=60

# Shorts threshold: videos 30s-3min (180s) → YouTube Shorts (9:16)
# Videos longer than this → regular YouTube videos (16:9)
SHORT_MAX_DURATION_SECONDS=180

# ============================================================
# 📅 Daily Scheduling
# ============================================================

VIDEOS_PER_DAY=5

# Publish times (optional):
# - Leave empty for automatic distribution from 08:00 to 22:00
# - Set comma-separated times: 08:00,11:00,14:00,17:00,20:00
PUBLISH_TIMES=08:00,11:00,14:00,17:00,20:00

AUTO_PUBLISH=false

# ============================================================
# 🎬 YouTube Settings
# ============================================================

YOUTUBE_CATEGORY_ID=22
YOUTUBE_PRIVACY=public

# Optional: different category for Shorts (leave empty to use YOUTUBE_CATEGORY_ID)
YOUTUBE_SHORTS_CATEGORY_ID=

# ============================================================
# 🎨 Subtitle Settings
# ============================================================

SUBTITLE_ENABLED=true
SUBTITLE_FONT_SIZE=42
SUBTITLE_COLOR=#FFFFFF
SUBTITLE_BG_OPACITY=0.6

# ============================================================
# 🎥 FFmpeg / Video Rendering — PERFORMANCE
# ============================================================
# Limit FFmpeg/MoviePy threads to prevent CPU saturation on
# resource-constrained devices (e.g. Termux/Android, VPS).
# FFmpeg auto-detects ALL CPU cores by default → 800% CPU on
# 8-core devices → system freeze. Set this to 2 for phones.
FFMPEG_THREADS=2
# x264 preset: ultrafast→slower. "fast" is a good balance.
# Use "ultrafast" on very weak devices to reduce render time.
FFMPEG_PRESET=fast
# Max seconds for a single FFmpeg subprocess before timeout kill.
FFMPEG_TIMEOUT=900

# ============================================================
# 🔐 Security — IMPORTANT
# ============================================================

# Random secret key (32+ chars): python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_min_32_chars_here

# API access token — use in Authorization header
API_ACCESS_TOKEN=your_strong_api_token_here

# Allowed IPs (comma-separated)
ALLOWED_HOSTS=127.0.0.1

# Timezone for scheduling (IANA name, e.g. Asia/Riyadh, Africa/Cairo, UTC)
TIMEZONE=UTC

# ============================================================
# ⚙️ Server Settings
# ============================================================

HOST=127.0.0.1
PORT=8000
DEBUG=false
